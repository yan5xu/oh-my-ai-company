{
  "name": "oh-my-ai-company-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "worker:dev": "wrangler dev --remote --port 8787",
    "build": "tsc -b && vite build",
    "check": "tsc -b",
    "cf:types": "wrangler types",
    "db:migrate": "wrangler d1 migrations apply oh-my-ai-company-prod --remote",
    "data:export": "node scripts/export-vault.mjs .. generated/vault.sql",
    "data:sync": "npm run data:export && wrangler d1 execute oh-my-ai-company-prod --remote --file generated/vault.sql",
    "assets:sync": "node scripts/sync-assets.mjs ..",
    "deploy": "npm run build && wrangler deploy",
    "publish": "npm run db:migrate && npm run data:sync && npm run assets:sync && npm run deploy"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.19",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "@xyflow/react": "^12.8.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260713.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "wrangler": "4.110.0"
  }
}
