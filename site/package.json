{
  "name": "oh-my-ai-company-site",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local --port 8788",
    "worker:dev": "wrangler dev --remote --port 8787",
    "build": "npm run check && npm run build:ui",
    "build:ui": "node scripts/build-memex-ui.mjs",
    "check": "tsc -p tsconfig.worker.json && tsc -p tsconfig.home.json",
    "cf:types": "wrangler types",
    "db:migrate": "wrangler d1 migrations apply oh-my-ai-company-prod --remote",
    "data:export": "node scripts/export-vault.mjs .. generated/vault.sql",
    "publication:check": "npm run data:export && node scripts/check-publication.mjs",
    "seo:verify": "node scripts/verify-seo.mjs",
    "data:sync": "npm run publication:check && wrangler d1 execute oh-my-ai-company-prod --remote --file generated/vault.sql",
    "assets:sync": "node scripts/sync-assets.mjs ..",
    "indexnow:dry-run": "node scripts/submit-indexnow.mjs --dry-run",
    "indexnow:submit": "node scripts/submit-indexnow.mjs",
    "deploy": "npm run build && wrangler deploy",
    "publish": "npm run db:migrate && npm run data:sync && npm run deploy && npm run assets:sync && npm run indexnow:submit"
  },
  "dependencies": {
    "marked": "^16.4.2",
    "sanitize-html": "^2.17.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260713.1",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "wrangler": "4.110.0"
  }
}
