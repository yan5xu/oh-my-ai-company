{
  "version": 1,
  "companies": [
    "company.kernel",
    "company.browserbase",
    "company.browserless",
    "company.hyperbrowser",
    "company.browser-use",
    "company.viktor",
    "company.dust",
    "company.tasklet",
    "company.superset"
  ],
  "source_policy": {
    "quality": ["full", "partial"],
    "evidence_level": ["S1", "S2", "S3"],
    "processing_status": ["summarized", "linked"]
  },
  "investment_policy": {
    "confidence": ["high", "medium"],
    "require_evidence": true
  },
  "touchpoint_policy": {
    "platform": ["Website", "X", "GitHub", "YC", "LinkedIn", "ProductHunt"],
    "status": ["active"]
  },
  "concept_policy": {
    "status": ["active"]
  },
  "graph_view_overrides": {
    "company-research-map": {
      "description": "公司一屏全景：证据、触点、流量、创始人、投资人和关联概念。"
    },
    "person-network": {
      "description": "人物全景：关联公司、公开证据和持续触点。"
    },
    "concept-evidence": {
      "description": "概念与模式的公开证据及相关公司。"
    },
    "source-trail": {
      "description": "从单条证据追到相关主体、触点、投资关系和概念。"
    }
  },
  "field_allowlist": {
    "company": ["name", "slug", "founders", "status", "one_liner", "category", "yc_url", "website", "launch_date", "title", "tags"],
    "person": ["name", "role", "founded_companies", "bio", "x_url", "linkedin_url", "title"],
    "investor": ["name", "kind", "website", "x_url", "linkedin_url", "focus", "tags", "title"],
    "investment": ["title", "investor", "company", "round", "amount_text", "announced_at", "role", "confidence", "evidence_items", "tags"],
    "source.item": ["item_type", "platform", "url", "title", "author", "published_at", "collected_at", "quality", "evidence_level", "processing_status", "about_company", "about_person", "about_investor"],
    "traffic.snapshot": ["title", "company", "platform", "domain", "period_start", "period_end", "collected_at", "geo", "web_source", "include_subdomains", "total_visits", "monthly_visits", "unique_visitors", "visit_duration_seconds", "pages_per_visit", "bounce_rate_pct", "desktop_share_pct", "mobile_share_pct", "global_rank", "country_rank", "country_rank_country", "category_rank", "category", "direct_pct", "organic_search_pct", "paid_search_pct", "referral_pct", "organic_social_pct", "paid_social_pct", "gen_ai_pct", "email_pct", "display_ads_pct", "search_traffic", "keyword_count", "branded_search_pct", "nonbranded_search_pct", "similar_domains", "quality"],
    "touchpoint": ["platform", "kind", "url", "handle", "title", "owner_company", "owner_person", "owner_investor", "status"],
    "concept": ["title", "kind", "summary", "status", "confidence", "related_companies", "evidence_items", "created_at", "tags"]
  },
  "asset_allowlist": [
    "assets/browser-use/home.png",
    "assets/browserbase-director-hero-2026-07-11.png",
    "assets/browserbase-stagehand-hero-2026-07-11.png",
    "assets/browserless/home.png",
    "assets/company.tasklet/legacy-render.png",
    "assets/dust/homepage-hero-2026-07-09.png",
    "assets/dust/pricing-plans-2026-07-09.png",
    "assets/dust/product-capabilities-2026-07-09.png",
    "assets/dust/security-controls-2026-07-09.png",
    "assets/hyperbrowser/home-main.png",
    "assets/kernel/cloudflare-web-bot-auth.png",
    "assets/kernel/homepage-hero.png",
    "assets/kernel/wordmark.png"
  ],
  "asset_deny_patterns": [
    "similarweb",
    "semrush",
    "linkedin",
    "traffic",
    "snapshot",
    "manifest",
    "raw/"
  ],
  "sensitive_body_patterns": [
    "/Users/",
    "/tmp/",
    "pinix_session=",
    "api_key=",
    "Authorization: Bearer",
    "sk-proj-"
  ]
}
